#!/usr/bin/expect

# Generate TOTP upfront
set totp [exec totp $env(HF_OVPN_OTP_SECRET)]
puts "✓ OTP ready"

spawn sudo openvpn \
    --config /Users/nv/Documents/hf/dev/hyperface-np-mgmt_VarunNair_hyperface-np-mgmt.ovpn \
    --auth-user-pass \
    --auth-retry interact

expect "Password:"
send "101010\r"
# interact {
#     "\r" { send "\r"; return }
# }

expect "Enter Auth Username:"
send "nv\r"

expect "Enter Auth Password:"
send "\r"

expect "CHALLENGE: Enter OTP Code"
send "$totp\r"

interact

